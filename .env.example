# Application
NODE_ENV=development
PORT=3000
APP_NAME=node56
APP_VERSION=1.0.0

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=node56_db
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_SSL=false
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Security
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info